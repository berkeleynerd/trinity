#ifdef GL_ES
precision mediump float;
#endif

#ifdef PS
uniform vec4 ssi;
varying float ssv;
#endif

varying vec2 texCoord;

uniform sampler2D s0;

void main()
{
    gl_FragColor = texture2D( s0, texCoord );
#ifdef PS
float av=floor(clamp(gl_FragColor.a,0.0,1.0)*255.0+0.5);
if(ssi.z==0.0)
{
if(av*ssi.x+ssi.y<0.0)
discard;
}
else
{
if(av==ssi.y)
discard;
}
if(ssv<0.0)discard;
#endif
}