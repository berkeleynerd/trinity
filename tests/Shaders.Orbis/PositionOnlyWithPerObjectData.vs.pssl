#include "ShadowState.fxh"

struct VS_OUTPUT
{
	float4 Position : S_POSITION;
	SHADOW_VS_OUTPUT
};

struct VS_INPUT
{
    float3 Position : POSITION;
    uint id : S_VERTEX_ID;
};


ConstantBuffer PerObjectDataCB: register( b0 )
{
    struct PerObjectData
    {
        float2 offset;
    } PerObject;
};

VS_OUTPUT main( VS_INPUT input )
{
	VS_OUTPUT Output;
	Output.Position = float4(input.Position + float3( PerObject.offset, 0 ), 1);
    SHADOW_VS_PART(Output, Position);
	return Output;    
}
